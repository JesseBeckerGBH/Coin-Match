# CoinMatch Backend Environment Variables
# Copy to .env and fill in values

# Database (get from Railway Postgres service)
DATABASE_URL=postgresql://user:pass@host:5432/coinmatch

# Redis (get from Railway Redis service)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=generate-at-https://generate-secret.vercel.app/64

# Stripe Connect
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google OAuth (optional for MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App
APP_ENV=production
APP_URL=https://your-domain.com
CORS_ORIGINS=https://your-domain.com
OWNER_EMAIL=jessebecker2021@gmail.com
PORT=8000
